pipeline {
    agent any

    environment {
        KAGGLEHUB_CACHE = "${WORKSPACE}/.kagglehub"
    }

    stages {
        stage('Prepare Workspace') {
            steps {
                sh '''
                    set -eu
                    cp -r /var/jenkins_home/shared/lab2/. .
                '''
            }
        }

        stage('Data Collection') {
            steps {
                sh '''
                    set -eu
                    python3 -m venv .venv
                    . .venv/bin/activate
                    python -m pip install -r requirements.txt
                    python create_dataset.py
                '''
            }
        }

        stage('Preprocessing') {
            steps {
                sh '''
                    set -eu
                    . .venv/bin/activate
                    python preprocess.py
                '''
            }
        }

        stage('Training') {
            steps {
                sh '''
                    set -eu
                    . .venv/bin/activate
                    python train_model.py
                '''
            }
        }

        stage('Evaluation') {
            steps {
                sh '''
                    set -eu
                    . .venv/bin/activate
                    python evaluate_model.py
                '''
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'artifacts/**/*', allowEmptyArchive: true
        }
    }
}
